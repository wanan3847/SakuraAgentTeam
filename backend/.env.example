# Application
APP_NAME=SakuraAgentTeam
APP_VERSION=0.1.0
DEBUG=false

# Server
HOST=0.0.0.0
PORT=8000

# LLM Providers (system-level shared key, optional)
# 同时只能有一个生效（由 DEFAULT_LLM_PROVIDER 决定）
# 获取 key：OpenAI → https://platform.openai.com/api-keys
#         Anthropic → https://console.anthropic.com/settings/keys
OPENAI_API_KEY=sk-your-openai-key-here
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here
DEFAULT_LLM_PROVIDER=openai
DEFAULT_LLM_MODEL=gpt-4o

# ⚠️ 安全提示：永远不要把真实 key 提交到 git
# .env 已在 .gitignore 排除

# Local model support (optional)
# LOCAL_MODEL_BASE_URL=http://localhost:11434

# JWT signing secret — 生产请改成 `openssl rand -hex 32`
SECRET_KEY=change-me-in-production-please-use-openssl-rand-hex-32

# Database
DATABASE_URL=sqlite+aiosqlite:///./data/sakura.db

# Experience store
EXPERIENCE_DB_PATH=./data/experience_db

# Projects
PROJECTS_ROOT=./data/projects

# Docker sandbox
SANDBOX_IMAGE=python:3.11-slim
SANDBOX_TIMEOUT=300

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# CORS（生产建议改成你的域名，多个用逗号分隔）
# CORS_ALLOW_ORIGINS=https://sakura.yourdomain.com
