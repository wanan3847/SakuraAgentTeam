{
  "name": "sakura-agent-team-desktop",
  "version": "0.2.0",
  "description": "🌸 樱花小队 — 桌面应用壳",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "node build.js",
    "build:mac": "node build.js --mac",
    "build:win": "node build.js --win",
    "build:all": "node build.js --all"
  },
  "dependencies": {},
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.13.0"
  },
  "build": {
    "appId": "com.wanan3847.sakuraagentteam",
    "productName": "SakuraAgentTeam",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": ["dmg", "zip"],
      "icon": "icons/sakura.icns"
    },
    "win": {
      "target": ["nsis", "portable"],
      "icon": "icons/sakura.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
