{
  "name": "sakura-agent-team-desktop",
  "version": "0.2.0",
  "description": "🌸 樱花小队 — 桌面应用壳",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "node build.js",
    "build:mac": "node build.js --mac",
    "build:win": "node build.js --win",
    "build:linux": "node build.js --linux",
    "build:all": "node build.js --all"
  },
  "dependencies": {},
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.13.0"
  },
  "build": {
    "appId": "com.wanan3847.sakuraagentteam",
    "productName": "SakuraAgentTeam",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "bin/**",
      "frontend-dist/**"
    ],
    "extraResources": [
      {
        "from": "bin",
        "to": "bin"
      },
      {
        "from": "frontend-dist",
        "to": "frontend-dist"
      }
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        {"target": "dmg", "arch": ["arm64", "x64"]},
        {"target": "zip", "arch": ["arm64", "x64"]}
      ],
      "icon": "build/icon.png",
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "identity": null
    },
    "win": {
      "target": ["nsis", "portable"],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "icon": "build/icon.png",
      "category": "Development"
    },
    "dmg": {
      "title": "樱花小队 SakuraAgentTeam ${version}",
      "contents": [
        {"x": 130, "y": 220, "type": "file"},
        {"x": 410, "y": 220, "type": "link", "path": "/Applications"}
      ]
    }
  }
}
